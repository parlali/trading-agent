
FROM oven/bun:1 AS pruner
WORKDIR /app

COPY package.json bun.lock turbo.json tsconfig.json ./
COPY apps ./apps
COPY packages ./packages

RUN bunx turbo prune @valiq-trading/backend --docker

# =========================================================================== #
# =========================================================================== #

FROM oven/bun:1 AS builder
WORKDIR /app

COPY --from=pruner /app/out/json/ .
COPY --from=pruner /app/tsconfig.json ./tsconfig.json
COPY --from=pruner /app/turbo.json ./turbo.json

RUN bun install
COPY --from=pruner /app/out/full/ .
RUN bunx turbo build --concurrency=1

# =========================================================================== #
# =========================================================================== #

FROM oven/bun:1 AS runner
WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates nodejs openssl \
    && update-ca-certificates \
    && rm -rf /var/lib/apt/lists/*
RUN bun install -g @openai/codex@0.138.0

COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/package.json ./package.json
COPY --from=builder /app/tsconfig.json ./tsconfig.json
COPY --from=builder /app/packages ./packages
COPY --from=builder /app/apps/backend ./apps/backend

WORKDIR /app/apps/backend

ENV NODE_ENV=production
ENV BACKEND_SERVICE_TOKEN=""
ENV CODEX_HOME=/var/lib/valiq/codex
ENV SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt
ENV CODEX_CA_CERTIFICATE=/etc/ssl/certs/ca-certificates.crt
RUN mkdir -p /var/lib/valiq/codex && chmod 700 /var/lib/valiq/codex
EXPOSE 3100
CMD ["bun", "run", "src/index.ts"]

# =========================================================================== #
