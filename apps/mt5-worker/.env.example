# MT5 Python Worker Configuration
# Copy to .env and fill in values

# Worker HTTP server
WORKER_HOST=0.0.0.0
WORKER_PORT=8090

# Shared auth key (must match MT5_WORKER_ACCESS_KEY in Convex env vars)
# Required for all worker endpoints, including /health
WORKER_ACCESS_KEY=

# MT5 terminal paths (Windows)
# Use a worker-specific root when this machine runs any other MT5 automation.
MT5_PORTABLE_DIR=C:\mt5-trading
MT5_TERMINAL_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
# Required broker server database. By default the worker expects <repo>\private\mt5-worker\servers.dat.
# Set MT5_SERVERS_DAT_PATH only if you keep the file somewhere else.
# MT5_SERVERS_DAT_PATH=C:\path\to\trading\private\mt5-worker\servers.dat
MT5_INITIALIZE_TIMEOUT_MS=60000

# Connection retry settings
RECONNECT_MAX_RETRIES=3
RECONNECT_DELAY_SECONDS=5.0
MT5_CONNECT_TIMEOUT_SECONDS=75.0
MT5_OPERATION_TIMEOUT_SECONDS=30.0
MT5_OPERATION_QUEUE_TIMEOUT_SECONDS=20.0

# Listener watchdog
WORKER_LISTENER_WATCHDOG_ENABLED=true
WORKER_LISTENER_WATCHDOG_STARTUP_GRACE_SECONDS=15.0
WORKER_LISTENER_WATCHDOG_INTERVAL_SECONDS=5.0
WORKER_LISTENER_WATCHDOG_TIMEOUT_SECONDS=2.0
WORKER_LISTENER_WATCHDOG_FAILURE_THRESHOLD=3

# Parent-process supervisor
WORKER_SUPERVISOR_STARTUP_GRACE_SECONDS=20.0
WORKER_SUPERVISOR_INTERVAL_SECONDS=5.0
WORKER_SUPERVISOR_TIMEOUT_SECONDS=3.0
WORKER_SUPERVISOR_FAILURE_THRESHOLD=2
WORKER_SUPERVISOR_ACTIVE_OPERATION_GRACE_SECONDS=90.0
WORKER_SUPERVISOR_RESTART_DELAY_SECONDS=2.0

# Optional Windows deployment guard. Set to the expected deployed repo path suffix
# when the worker should fail closed unless it is running from that path.
WORKER_EXPECTED_REPO_SUFFIX=
