{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "types": ["node"],
        "declaration": true,
        "declarationMap": true,
        "outDir": "dist",
        "rootDir": "."
    },
    "include": ["convex/**/*.ts", "src/**/*.ts"],
    "exclude": ["node_modules", "dist"]
}
