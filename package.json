{
    "name": "valiq-trading",
    "version": "0.0.1",
    "private": true,
    "packageManager": "bun@1.3.0",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "turbo dev --filter=@valiq-trading/backend --filter=dashboard",
        "dev:backend": "bun --watch apps/backend/src/index.ts",
        "dev:dashboard": "cd apps/dashboard && bun run dev",
        "test": "bunx vitest run",
        "strategies:diff": "cd apps/backend && bun run strategies:diff",
        "strategies:list": "cd apps/backend && bun run strategies:list",
        "strategies:add": "cd apps/backend && bun run strategies:add",
        "strategies:add-all": "cd apps/backend && bun run strategies:add-all",
        "strategies:delete": "cd apps/backend && bun run strategies:delete",
        "strategies:reset": "cd apps/backend && bun run strategies:reset",
        "strategies:force-reset": "cd apps/backend && bun run strategies:force-reset",
        "strategies:reset-import": "cd apps/backend && bun run strategies:reset-import",
        "positions:unowned": "cd apps/backend && bun run positions:unowned",
        "build": "turbo build",
        "lint": "turbo lint",
        "clean": "bun run clean:modules && bun run clean:dist",
        "clean:modules": "rm -rf node_modules && rm -rf apps/*/node_modules && rm -rf packages/*/node_modules",
        "clean:dist": "rm -rf apps/*/dist && rm -rf packages/*/dist"
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "turbo": "^2.8.20",
        "typescript": "^6.0.2",
        "vitest": "^4.1.2"
    }
}
